# ===========================================
# RIZQ App - Environment Variables Template
# ===========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env with real credentials.
# ===========================================

# -------------------------------------------
# Firebase (required since M1 cutover)
# -------------------------------------------
# Get these from Firebase Console > Project Settings > General > Web app.
# Firestore is the single source of truth for both content and user data.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=rizq-app-c6468
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# -------------------------------------------
# Local development (optional)
# -------------------------------------------
# Set to "true" only when running against the Firebase Auth + Firestore
# emulator suite (used by e2e tests).
VITE_USE_FIREBASE_EMULATORS=false
